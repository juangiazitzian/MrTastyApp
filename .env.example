# Base de datos (SQLite por defecto, cambiar a postgres:// para producción)
DATABASE_URL="file:./dev.db"

# API de parseo de imágenes (OCR)
# Opciones: "mock" | "anthropic" | "openai"
DOCUMENT_PARSER_PROVIDER="mock"

# Si usás Anthropic Claude Vision (recomendado):
# ANTHROPIC_API_KEY="sk-ant-..."

# Si usás OpenAI Vision:
# OPENAI_API_KEY="sk-..."

# Autenticación — generá un secreto fuerte para producción
AUTH_SECRET="cambiar-en-produccion"

# Puerto (opcional)
PORT=3000

# Moneda por defecto
DEFAULT_CURRENCY="ARS"

# Timezone
TZ="America/Argentina/Buenos_Aires"
