# Base de datos (SQLite por defecto, cambiar a postgres:// para producción)
DATABASE_URL="file:./dev.db"

# API de parseo de imágenes (OCR)
# Opciones: "openai" | "anthropic" | "mock"
DOCUMENT_PARSER_PROVIDER="mock"

# Si usás OpenAI Vision:
OPENAI_API_KEY="sk-..."

# Si usás Anthropic Claude Vision:
ANTHROPIC_API_KEY="sk-ant-..."

# Puerto (opcional)
PORT=3000

# Moneda por defecto
DEFAULT_CURRENCY="ARS"

# Timezone
TZ="America/Argentina/Buenos_Aires"
